# Godot 4+ specific ignores
.godot/
/android/

# Runtime model installs and partial downloads are never repository assets.
**/*.litertlm
**/*.litertlm.part
**/*.part

# Runtime state belongs in the OS application-support directory.
**/*.sqlite
**/*.sqlite3
**/*.sqlite-*
**/*.sqlite3-*
**/*.db
**/*.db-*
**/*.key

# Local credentials and signing material.
**/.env
**/.env.*
!**/.env.example
**/*.jks
**/*.keystore
**/*.p12
**/*.mobileprovision

# Generated Flutter/Dart and release output, including the reference app.
**/.dart_tool/
**/.pub-cache/
**/.flutter-home/
**/.tooling/
**/build/
**/coverage/
dist/
exports/
release/
default.profraw
